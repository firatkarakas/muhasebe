{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Muhasebe uygulama izinleri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:allow-close",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" }
      ]
    }
  ]
}
